{
  "extends": "../../tsconfig/bundler.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "noUnusedLocals": false,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "lib": ["ES2023", "ScriptHost"],
    "target": "ESNext"
  },
  "include": ["./src"]
}
